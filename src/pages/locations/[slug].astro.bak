---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, all: locations },
  }));
}

interface Props {
  entry: CollectionEntry<'locations'>;
  all: CollectionEntry<'locations'>[];
}
const { entry, all } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

const title = data.headline ?? `Pre-purchase building inspections in ${data.suburb}`;
const description = data.metaDescription;

// Neighbouring suburbs — same tier first, then any others, excluding self.
const neighbours = all
  .filter((l) => l.slug !== entry.slug)
  .sort((a, b) => {
    if (a.data.tier === data.tier && b.data.tier !== data.tier) return -1;
    if (a.data.tier !== data.tier && b.data.tier === data.tier) return 1;
    return a.data.order - b.data.order;
  })
  .slice(0, 4);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Pre-purchase building inspection',
  provider: { '@id': 'https://inspections.wayfarecon.com/#business' },
  areaServed: {
    '@type': 'Place',
    name: data.suburb,
    address: {
      '@type': 'PostalAddress',
      addressLocality: data.suburb,
      postalCode: data.postcode,
      addressRegion: data.state,
      addressCountry: 'AU',
    },
  },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'AUD',
    price: '595',
    availability: 'https://schema.org/InStock',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://inspections.wayfarecon.com/' },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: 'https://inspections.wayfarecon.com/locations/' },
    { '@type': 'ListItem', position: 3, name: data.suburb, item: `https://inspections.wayfarecon.com/locations/${entry.slug}/` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `How quickly can you do a building inspection in ${data.suburb}?`,
      acceptedAnswer: { '@type': 'Answer', text: `${data.suburb} is about ${data.driveMinutes} minutes from Mildura, so I can usually get on site within 24 to 48 hours of booking. Reports are delivered within 24 hours of the inspection.` },
    },
    {
      '@type': 'Question',
      name: `How much does a building inspection in ${data.suburb} cost?`,
      acceptedAnswer: { '@type': 'Answer', text: 'A standard pre-purchase inspection in the Mildura region starts at $595. Combined building and pest is $795. Rural properties or larger homes may attract a small surcharge — always quoted upfront.' },
    },
  ],
};
---
<BaseLayout title={title} description={description} schema={[serviceSchema, breadcrumbSchema, faqSchema]}>

  <section class="hero hero--inner">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a><span>·</span><a href="/locations/">Locations</a><span>·</span>{data.suburb}</p>
      <h1>{title}</h1>
      <p class="lede">{data.summary}</p>
      <div class="actions mt-4">
        <a href="/book/" class="btn btn--primary btn--lg">Book an inspection in {data.suburb}</a>
        <a href="tel:+61417875329" class="phone">0417 875 329</a>
      </div>
    </div>
  </section>

  <!-- Local context — the unique-content moat -->
  <section>
    <div class="wrap wrap--narrow">
      <div class="section-head">
        <p class="eyebrow">{data.suburb} · {data.postcode} · {data.state}</p>
        <h2 class="h-2">Why building inspections in {data.suburb} matter</h2>
      </div>
      <div class="prose"><Content /></div>

      {data.commonDefects && (
        <div class="mt-5">
          <p class="eyebrow">What I look for</p>
          <h3 class="h-3 mb-3">Common findings in {data.suburb} properties</h3>
          <ul class="defects">
            {data.commonDefects.map((d) => <li>{d}</li>)}
          </ul>
        </div>
      )}
    </div>
  </section>

  <!-- What's included -->
  <section class="alt">
    <div class="wrap wrap--narrow">
      <p class="eyebrow">What's included</p>
      <h2 class="h-2 mb-4">What you get with every inspection</h2>
      <ol class="steps">
        <li><strong>A full property walk-through.</strong> Roof, sub-floor, exterior, every room, structural through to finish. Two to three hours on site.</li>
        <li><strong>A 40–60 page PDF report.</strong> Plain English. Every finding photographed. Severity ratings so you know what's urgent.</li>
        <li><strong>A short video walk-through.</strong> Useful if you're buying remotely or you want to show family.</li>
        <li><strong>A same-day phone call.</strong> I ring you when the report lands to talk it through and answer questions.</li>
      </ol>
      <div class="mt-5 center">
        <a href="/services/pre-purchase-building-inspection/" class="btn btn--ghost">Full service details</a>
        <a href="/sample-report/" class="btn btn--ghost" style="margin-left:8px;">See sample report</a>
      </div>
    </div>
  </section>

  <!-- Pricing strip -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Pricing in {data.suburb}</p>
        <h2 class="h-2">From $595 — published, not quoted</h2>
        <p class="lede">Wayfare publishes prices upfront. Most competitors hide them behind an enquiry form. You can see exactly what an inspection in {data.suburb} costs before you commit.</p>
      </div>
      <div class="grid grid--2">
        <div class="price-tier">
          <h3>Standard pre-purchase</h3>
          <p class="price">$595 <small>from</small></p>
          <ul>
            <li>Full inspection in {data.suburb}</li>
            <li>40–60 page photo-rich PDF report</li>
            <li>Video walk-through</li>
            <li>Same-day phone call</li>
            <li>Report in 24 hours</li>
          </ul>
          <a href="/book/" class="btn btn--primary btn--full">Book a standard inspection</a>
        </div>
        <div class="price-tier featured">
          <h3>Building + pest</h3>
          <p class="price">$795 <small>combined</small></p>
          <ul>
            <li>Standard inspection plus</li>
            <li>Timber-pest report by a licensed specialist</li>
            <li>Single coordinated visit</li>
            <li>Single combined report</li>
            <li>Report in 24 hours</li>
          </ul>
          <a href="/book/" class="btn btn--ink btn--full">Book building + pest</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Neighbouring suburbs -->
  {neighbours.length > 0 && (
    <section class="alt">
      <div class="wrap">
        <div class="section-head">
          <p class="eyebrow">Nearby</p>
          <h2 class="h-2">Also inspecting in</h2>
        </div>
        <div class="grid grid--4">
          {neighbours.map((n) => (
            <a href={`/locations/${n.slug}/`} class="pillar" style="text-decoration:none;">
              <p class="label">Service area</p>
              <h3 style="font-size:18px;">{n.data.suburb}</h3>
              <p style="font-size:13px;">{n.data.summary.split('.')[0]}.</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Trust + final CTA -->
  <section class="dark">
    <div class="wrap center">
      <h2 class="h-1">Inspecting in {data.suburb} this week.</h2>
      <p class="lede mt-3" style="margin-left:auto;margin-right:auto;">Book online in three minutes or ring me on 0417 875 329.</p>
      <div class="mt-5">
        <a href="/book/" class="btn btn--primary btn--lg">Book an inspection</a>
        <a href="tel:+61417875329" class="btn btn--ghost-cream btn--lg" style="margin-left:8px;">0417 875 329</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .prose p { font-size: 16px; line-height: 1.7; margin: 0 0 1em; color: var(--charcoal); }
  .prose p:last-child { margin-bottom: 0; }
  .defects { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--space-2); }
  .defects li {
    font-size: 15px;
    padding-left: var(--space-4);
    position: relative;
    line-height: 1.55;
  }
  .defects li::before {
    content: "↪";
    position: absolute;
    left: 0;
    color: var(--mallee);
    font-family: var(--font-mono);
  }
</style>
