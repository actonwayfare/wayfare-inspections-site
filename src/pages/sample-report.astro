---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Sample pre-purchase inspection report';
const description = 'A redacted sample of a real Wayfare Construction Inspections pre-purchase report. Photos, severity ratings, plain English.';
---
<BaseLayout title={title} description={description}>
  <section class="hero hero--inner">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a><span>·</span>Sample report</p>
      <h1>This is exactly what you'll get.</h1>
      <p class="lede">A redacted version of a real Wayfare pre-purchase inspection report. Take a look before you book.</p>
    </div>
  </section>

  <section>
    <div class="wrap wrap--narrow">
      <div class="card card--feature">
        <p class="eyebrow">PDF preview</p>
        <h2 class="h-3 mb-3">Sample report — Mildura, three-bedroom weatherboard</h2>
        <p>This is a redacted real-world example (client name and exact address removed). It's a typical Wayfare deliverable for a standard pre-purchase inspection.</p>
        <p class="mt-3">
          <a href="/reports/sample-report.pdf" class="btn btn--primary">Download the sample PDF</a>
          <span class="small" style="margin-left:var(--space-3);">~6 MB · 48 pages</span>
        </p>
      </div>

      <h2 class="h-2 mt-5 mb-3">What to look for in the report</h2>
      <ul class="steps mt-3">
        <li><strong>Severity ratings.</strong> Every finding is rated <em>safety · major · minor · cosmetic · maintenance</em>. You can skim straight to the safety items.</li>
        <li><strong>Photos.</strong> Every notable finding is photographed with context. No vague "settled paint" claims without proof.</li>
        <li><strong>Plain English.</strong> No jargon unless we explain it. If you're not a builder, you won't need to Google a single word.</li>
        <li><strong>Recommendations.</strong> Where action is needed, we say what kind of trade you'd call (roofer, electrician, builder) and what rough scope.</li>
      </ul>

      <div class="mt-5 center">
        <a href="/book/" class="btn btn--primary btn--lg">Book an inspection</a>
      </div>
    </div>
  </section>
</BaseLayout>
