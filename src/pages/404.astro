---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found" description="That page doesn't exist on Wayfare Construction Inspections.">
  <section class="hero hero--inner">
    <div class="wrap center">
      <p class="eyebrow eyebrow--cream">404</p>
      <h1>That page is missing.</h1>
      <p class="lede" style="margin-left:auto;margin-right:auto;">Either it's never existed or it's moved. Try the links below, or call 0417 875 329 if you're stuck.</p>
    </div>
  </section>

  <section>
    <div class="wrap center">
      <div class="grid grid--3" style="max-width:720px;margin:0 auto;">
        <a href="/" class="pillar" style="text-decoration:none;"><h3 style="font-size:18px;">Home</h3><p style="font-size:13px;">Start over.</p></a>
        <a href="/services/pre-purchase-building-inspection/" class="pillar" style="text-decoration:none;"><h3 style="font-size:18px;">Inspections</h3><p style="font-size:13px;">What's included.</p></a>
        <a href="/book/" class="pillar" style="text-decoration:none;"><h3 style="font-size:18px;">Book</h3><p style="font-size:13px;">Three minutes online.</p></a>
      </div>
    </div>
  </section>
</BaseLayout>
