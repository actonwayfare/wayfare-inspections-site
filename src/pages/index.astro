---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Pre-purchase building inspections in Mildura';
const description = 'Mildura\'s owner-operator pre-purchase building inspector. Licensed builder, plain-English reports, 24-hour turnaround. From $550 inc. GST.';

const tierASuburbs = [
  { name: 'Mildura', slug: 'mildura' },
  { name: 'Gol Gol', slug: 'gol-gol' },
  { name: 'Irymple', slug: 'irymple' },
  { name: 'Red Cliffs', slug: 'red-cliffs' },
  { name: 'Merbein', slug: 'merbein' },
  { name: 'Buronga', slug: 'buronga' },
  { name: 'Wentworth', slug: 'wentworth' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does a pre-purchase building inspection cost in Mildura?',
      acceptedAnswer: { '@type': 'Answer', text: 'A standard pre-purchase inspection (1–3 bedrooms, single-storey, slab) is $550 inc. GST. Bigger homes, double-storey, stumps, sheds, granny flats or a pool add a transparent extra — the booking quiz gives you a final price in 30 seconds before you pick a slot. All add-ons are published on the pricing page.' },
    },
    {
      '@type': 'Question',
      name: 'How quickly will I get the report?',
      acceptedAnswer: { '@type': 'Answer', text: 'The full written report lands in your inbox within 24 hours of the inspection — usually sooner.' },
    },
    {
      '@type': 'Question',
      name: 'Do I have to be at the inspection?',
      acceptedAnswer: { '@type': 'Answer', text: 'No. Most buyers are not on site. The inspection is scheduled with the selling agent or vendor, and the full written report lands in your inbox within 24 hours.' },
    },
  ],
};
---
<BaseLayout title={title} description={description} schema={[faqSchema]}>

  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow eyebrow--cream">Pre-purchase building inspections · Mildura &amp; Sunraysia</p>
      <h1>The kind of inspection only a builder can give you.</h1>
      <p class="lede">I'm Acton. I'm a registered builder who has been in construction for 17 years. Now I write the kind of pre-purchase inspection report I'd want before buying a house myself — plain English, every finding photographed, every defect rated.</p>
      <div class="actions">
        <a href="/book/" class="btn btn--primary btn--lg">Book an inspection</a>
        <a href="/sample-report/" class="btn btn--ghost-cream btn--lg">See a sample report</a>
        <a href="tel:+61417875329" class="phone">0417 875 329</a>
      </div>
      <p class="hero-licence">
        <span class="hero-licence__row">
          Licensed builder · <strong>Cert IV CPC40110</strong>
        </span>
        <span class="hero-licence__row">
          <strong>DB-U 100124</strong> <span class="hero-licence__tag">individual</span>
          <a href="https://bams.vba.vic.gov.au/bams/s/practitioner-detail?inputParams=6SEnE%2B3km9FbBYSW9%2BgSXprFl9TfFtzEO7k2kyt1%2FRY6WNRXz5FZz89rG2msdHkD" target="_blank" rel="noopener">Verify on the BPC register →</a>
        </span>
        <span class="hero-licence__row">
          <strong>CDB-U 100482</strong> <span class="hero-licence__tag">company</span>
          <a href="https://bams.vba.vic.gov.au/bams/s/practitioner-detail?inputParams=hb1R8neUjHAj95EyWXZevcDUoGX3MYHd1wg5r83wI1dd7Zbs%2F0t6TCGmKyf8aPga" target="_blank" rel="noopener">Verify on the BPC register →</a>
        </span>
      </p>
    </div>
  </section>

  <!-- WHY -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Why Wayfare</p>
        <h2 class="h-1">Three reasons buyers choose us over the franchises.</h2>
      </div>
      <div class="grid grid--3">
        <div class="pillar">
          <p class="label">Experience</p>
          <h3>Builder, not box-ticker.</h3>
          <p>An inspector who has actually built the houses he inspects. That's the difference between reading a checklist and reading a craftsman's notes.</p>
        </div>
        <div class="pillar">
          <p class="label">Local</p>
          <h3>Local by birth, not by ad spend.</h3>
          <p>Born and raised in Mildura. I know the soils, the suburbs, the building stock, and the defects that show up in this climate.</p>
        </div>
        <div class="pillar">
          <p class="label">Reports</p>
          <h3>A report worth reading.</h3>
          <p>Plain English. Photos of every finding. Severity ratings on every defect so you know what's urgent and what's cosmetic. AS 4349.1 compliant.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="alt">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">How it works</p>
        <h2 class="h-1">Book online. Report in 24 hours. Pay when you're ready.</h2>
      </div>
      <ol class="steps">
        <li><strong>You book online.</strong> Pick a date that suits — takes three minutes. No card required to secure your slot.</li>
        <li><strong>I inspect the property.</strong> Roof to sub-floor, every room, structural through to finish. You don't need to be there.</li>
        <li><strong>You get the report within 24 hours.</strong> A photo-rich PDF with severity ratings on every finding. AS 4349.1 compliant.</li>
        <li><strong>I send a tax invoice.</strong> Pay by bank transfer or PayID — the full report is released to your inbox the moment payment lands.</li>
      </ol>
    </div>
  </section>

  <!-- PRICING STRIP -->
  <section>
    <div class="wrap wrap--narrow">
      <div class="section-head">
        <p class="eyebrow">Pricing</p>
        <h2 class="h-1">Honest pricing. No quotes, no surprises.</h2>
        <p class="lede">One of the few inspectors in Mildura that publishes prices. If you'd rather not chase three businesses for a quote, here it is.</p>
      </div>
      <div class="price-tier featured" style="text-align:center;">
        <h3>Pre-purchase building inspection</h3>
        <p class="price">from $550 <small>inc. GST</small></p>
        <p class="small">For a standard 1–3 bedroom, single-storey home on slab. The booking quiz gives you a final price in 30 seconds.</p>
        <ul style="text-align:left;">
          <li>Full inspection to AS 4349.1</li>
          <li>40–60 page photo-rich PDF report</li>
          <li>Severity rating on every finding</li>
          <li>Report delivered within 24 hours</li>
          <li>No card required at booking</li>
        </ul>
        <a href="/book/" class="btn btn--primary btn--full">Get instant quote &amp; book</a>
      </div>
      <p class="small center mt-4">Larger homes, double-storey, stumps, sheds, granny flats and pools add a transparent extra. <a href="/pricing/">See the full add-on list &rarr;</a></p>
    </div>
  </section>

  <!-- LOCATIONS -->
  <section class="alt">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Where we work</p>
        <h2 class="h-1">Mildura and immediate surrounds.</h2>
        <p class="lede">A 50-kilometre radius from Mildura. If you're buying in any of the suburbs below, we can be on site within days — often within 24 hours.</p>
      </div>
      <div class="grid grid--4">
        {tierASuburbs.map((s) => (
          <a href={`/locations/${s.slug}/`} class="pillar" style="text-decoration:none;">
            <p class="label">Service area</p>
            <h3 style="font-size:20px;">Inspections in {s.name}</h3>
            <p>Building inspector available in {s.name} for pre-purchase reports. <span style="color:var(--mallee);">Read more &rarr;</span></p>
          </a>
        ))}
      </div>
      <p class="center mt-4"><a href="/locations/" class="btn btn--ghost">See all service areas</a></p>
    </div>
  </section>

  <!-- TRUST -->
  <section class="alt">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Trust &amp; standards</p>
        <h2 class="h-1">Licensed. Insured. Accountable.</h2>
      </div>
      <div class="trust">
        <span class="badge">DB-U 100124</span>
        <span class="badge">CDB-U 100482</span>
        <span class="badge badge--steel">Cert IV · CPC40110</span>
        <span class="badge badge--steel">Master Builders member</span>
        <span class="badge badge--sand">PI + PL insured</span>
        <span class="badge badge--mallee">Reports in 24 hrs</span>
        <span class="badge badge--outline">Reports to AS 4349.1</span>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section>
    <div class="wrap wrap--narrow">
      <div class="section-head">
        <p class="eyebrow">Common questions</p>
        <h2 class="h-1">A few things buyers always ask.</h2>
      </div>
      <details class="faq-item" open>
        <summary>How much does a pre-purchase building inspection cost in Mildura?</summary>
        <div class="answer">A standard pre-purchase inspection (1–3 bedrooms, single-storey, slab) is $550 inc. GST. Bigger homes, double-storey, stumps, sheds, granny flats or a pool add a transparent extra — the <a href="/book/">booking quiz</a> gives you a final price in 30 seconds before you pick a slot. All add-ons are published on the <a href="/pricing/">pricing page</a>.</div>
      </details>
      <details class="faq-item">
        <summary>How quickly will I get the report?</summary>
        <div class="answer">The full written report lands in your inbox within 24 hours of the inspection — usually sooner.</div>
      </details>
      <details class="faq-item">
        <summary>Do I have to be at the inspection?</summary>
        <div class="answer">No. Most buyers aren't on site. We schedule with the selling agent or vendor, and the full written report lands in your inbox within 24 hours.</div>
      </details>
      <p class="center mt-4"><a href="/faqs/" class="btn btn--ghost">All FAQs</a></p>
    </div>
  </section>

  <!-- CTA -->
  <section class="dark">
    <div class="wrap center">
      <h2 class="h-1">Ready to book?</h2>
      <p class="lede mt-3" style="margin-left:auto;margin-right:auto;">Three minutes to book online. Calendar shows my real availability. Invoice sent after the inspection — your report is released the moment payment lands.</p>
      <div class="mt-5">
        <a href="/book/" class="btn btn--primary btn--lg">Book an inspection</a>
      </div>
      <p class="small mt-3" style="opacity:0.75;">All bookings are made through the online calendar. Questions before you book? Call <a href="tel:+61417875329" style="color:inherit;">0417 875 329</a>.</p>
    </div>
  </section>

</BaseLayout>
