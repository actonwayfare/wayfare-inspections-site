---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Book a pre-purchase building inspection — Mildura';
const description = 'Pick a date and time for your Mildura pre-purchase building inspection. No card required at booking — invoice sent after the inspection, report released on payment.';
---
<BaseLayout title={title} description={description}>
  <section class="hero hero--inner">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a><span>·</span>Book</p>
      <h1>Book your inspection.</h1>
      <p class="lede">Pick a date and time that suits. No card needed to book — I send a tax invoice after the inspection, and you receive the report once payment is settled.</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="booking-summary">
        <div>
          <p class="eyebrow">Pre-purchase building inspection</p>
          <p class="booking-summary__meta">Thorough on-site inspection · Photo-rich written report within 24 hours · AS 4349.1 compliant</p>
        </div>
        <div class="booking-summary__price">
          <span class="booking-summary__amount">$550</span>
          <span class="booking-summary__inc">inc. GST</span>
        </div>
      </div>

      <h2 class="h-3 mb-3 mt-5">Pick a date and time</h2>

      <div id="cal-inline" class="cal-embed"></div>

      <p class="small mt-3" style="color:var(--mid);">
        Can't see a slot that works? Urgent same-day or weekend slots may be available with a $150 surcharge — email <a href="mailto:wayfareinspections@gmail.com"><strong>wayfareinspections@gmail.com</strong></a> with the property address and preferred date, and I'll open up a slot if I can.
      </p>
    </div>
  </section>

  <section style="background:var(--cream);">
    <div class="wrap">
      <h2 class="h-3 mb-3">How payment works</h2>
      <p class="lede mb-4" style="max-width:65ch;">No deposit at booking. You pay once the inspection is done and before I release the report — keeps everything simple and fair.</p>

      <div class="payment-steps">
        <div class="payment-step">
          <span class="payment-step__num">01</span>
          <h3 class="payment-step__title">Pick your slot above</h3>
          <p>Calendar shows my real availability — no back-and-forth.</p>
        </div>
        <div class="payment-step">
          <span class="payment-step__num">02</span>
          <h3 class="payment-step__title">I inspect the property</h3>
          <p>You don't need to be there. Every system, every room — I take the time the property needs.</p>
        </div>
        <div class="payment-step">
          <span class="payment-step__num">03</span>
          <h3 class="payment-step__title">I write the report</h3>
          <p>Photo-rich, plain English. Within 24 hours of the inspection.</p>
        </div>
        <div class="payment-step">
          <span class="payment-step__num">04</span>
          <h3 class="payment-step__title">I send a tax invoice</h3>
          <p>Pay by bank transfer or PayID — whichever suits you.</p>
        </div>
        <div class="payment-step">
          <span class="payment-step__num">05</span>
          <h3 class="payment-step__title">Report is yours</h3>
          <p>Once payment lands, the full written report is released to your inbox. AS 4349.1 compliant, photo-rich, plain English.</p>
        </div>
      </div>

      <div class="info-cards mt-5">
        <div class="card">
          <h3 class="h-4 mb-2">Questions before booking?</h3>
          <p class="small">Call <a href="tel:+61417875329">0417 875 329</a> — I answer myself. Note: the calendar above is the only way to book. The phone is for questions only.</p>
        </div>
        <div class="card">
          <h3 class="h-4 mb-2">Cancellation</h3>
          <p class="small">Free to cancel or reschedule up to 24 hours before. Within 24 hours, a 50% fee applies — fair to both sides.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cal.com inline embed loader -->
  <script is:inline>
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ["initNamespace", namespace]);
          } else p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    Cal("init", "wayfare-inspection", { origin: "https://app.cal.com" });
    Cal.ns["wayfare-inspection"]("inline", {
      elementOrSelector: "#cal-inline",
      config: { layout: "month_view", useSlotsViewOnSmallScreen: "true" },
      calLink: "wayfare-inspections/pre-purchase-building-inspection",
    });
    Cal.ns["wayfare-inspection"]("ui", {
      hideEventTypeDetails: false,
      layout: "month_view",
      styles: { branding: { brandColor: "#B5472D" } }
    });
  </script>

  <style>
    .booking-summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
      flex-wrap: wrap;
      padding: var(--space-4);
      background: var(--mallee);
      color: var(--cream);
      border-radius: 10px;
    }
    .booking-summary .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.85rem;
      font-weight: 600;
      opacity: 0.85;
      margin-bottom: 4px;
    }
    .booking-summary__meta {
      font-size: 0.95rem;
      line-height: 1.5;
      margin: 0;
    }
    .booking-summary__price {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
    }
    .booking-summary__amount {
      font-size: 2rem;
      font-weight: 700;
      line-height: 1;
    }
    .booking-summary__inc {
      font-size: 0.85rem;
      opacity: 0.85;
      margin-top: 4px;
    }
    .cal-embed {
      width: 100%;
      min-height: 720px;
      background: #fff;
      border: 1px solid #e5e2dc;
      border-radius: 10px;
      overflow: auto;
    }
    .payment-steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: var(--space-4);
      margin-top: var(--space-3);
    }
    .payment-step {
      background: #fff;
      border: 1px solid #e5e2dc;
      border-radius: 10px;
      padding: var(--space-4);
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .payment-step__num {
      font-family: var(--font-mono, monospace);
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--mallee);
      letter-spacing: 0.06em;
    }
    .payment-step__title {
      font-family: var(--font-display, serif);
      font-size: 1.1rem;
      font-weight: 600;
      margin: 0;
      line-height: 1.3;
    }
    .payment-step p {
      margin: 0;
      font-size: 0.95rem;
      line-height: 1.55;
      color: var(--mid, #555);
    }
    .info-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--space-3);
    }
    @media (max-width: 760px) {
      .cal-embed {
        min-height: 680px;
      }
      .booking-summary {
        flex-direction: column;
        align-items: flex-start;
      }
      .booking-summary__price {
        align-items: flex-start;
      }
    }
  </style>
</BaseLayout>
