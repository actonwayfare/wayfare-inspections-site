---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Book a pre-purchase building inspection — Mildura';
const description = 'Five quick questions for a transparent price. Then pick a date and time. Takes about a minute.';
---
<BaseLayout title={title} description={description}>
  <section class="hero hero--inner">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a><span>·</span>Book</p>
      <h1>Book your inspection.</h1>
      <p class="lede">Five quick questions for an accurate price. Then pick a date and time. About a minute.</p>
    </div>
  </section>

  <section>
    <div class="wrap">

      <!-- ============ QUIZ ============ -->
      <div id="step1" class="quiz-block">

        <form id="quoteForm" class="quote-form" novalidate>

          <!-- Progress bar (sticky on mobile) -->
          <div class="qf-progress" aria-live="polite">
            <div class="qf-progress__row">
              <span class="qf-progress__step">Step <strong id="stepCurrent">1</strong> of <span id="stepTotal">6</span></span>
              <span class="qf-progress__price">
                <span id="progressPrice">from $495</span>
                <small>inc. GST</small>
              </span>
            </div>
            <div class="qf-progress__bar" aria-hidden="true">
              <span id="progressBar"></span>
            </div>
          </div>

          <!-- ===== Step 1: bedrooms ===== -->
          <fieldset class="qf-step is-active" data-step="1">
            <legend class="qf-step__title">How big is the house?</legend>
            <p class="qf-help">Pick the closest match.</p>
            <div class="qf-options">
              <label class="qf-option"><input type="radio" name="bedrooms" value="small" required><span>1&ndash;3 bedrooms<small>included in base</small></span></label>
              <label class="qf-option"><input type="radio" name="bedrooms" value="medium"><span>4&ndash;5 bedrooms<small>+ $70</small></span></label>
              <label class="qf-option qf-option--quote"><input type="radio" name="bedrooms" value="quote"><span>More than 5 bedrooms<small>routes to custom quote</small></span></label>
            </div>
            <div class="qf-nav">
              <button type="button" class="qf-back" data-action="back" disabled>&larr; Back</button>
              <button type="button" class="btn btn--primary qf-next" data-action="next" disabled>Next &rarr;</button>
            </div>
          </fieldset>

          <!-- ===== Step 2: storeys ===== -->
          <fieldset class="qf-step" data-step="2">
            <legend class="qf-step__title">Single or double storey?</legend>
            <p class="qf-help">Split-levels count as double.</p>
            <div class="qf-options">
              <label class="qf-option"><input type="radio" name="storeys" value="single" required><span>Single storey<small>included</small></span></label>
              <label class="qf-option"><input type="radio" name="storeys" value="double"><span>Double or split-level<small>+ $90</small></span></label>
            </div>
            <div class="qf-nav">
              <button type="button" class="qf-back" data-action="back">&larr; Back</button>
              <button type="button" class="btn btn--primary qf-next" data-action="next" disabled>Next &rarr;</button>
            </div>
          </fieldset>

          <!-- ===== Step 3: foundation ===== -->
          <fieldset class="qf-step" data-step="3">
            <legend class="qf-step__title">What's it built on?</legend>
            <p class="qf-help">If you're not sure, choose Not sure and I'll confirm on site.</p>
            <div class="qf-options">
              <label class="qf-option"><input type="radio" name="foundation" value="slab" required><span>Concrete slab on ground<small>included</small></span></label>
              <label class="qf-option"><input type="radio" name="foundation" value="stumps"><span>Stumps or brick piers<small>sub-floor access &middot; + $90</small></span></label>
              <label class="qf-option"><input type="radio" name="foundation" value="unsure"><span>Not sure<small>I&rsquo;ll confirm on inspection</small></span></label>
            </div>
            <div class="qf-nav">
              <button type="button" class="qf-back" data-action="back">&larr; Back</button>
              <button type="button" class="btn btn--primary qf-next" data-action="next" disabled>Next &rarr;</button>
            </div>
          </fieldset>

          <!-- ===== Step 4: outbuildings ===== -->
          <fieldset class="qf-step" data-step="4">
            <legend class="qf-step__title">Anything extra on the block?</legend>
            <p class="qf-help">Tick everything that applies, or skip if none. A small garden shed under 10&nbsp;m&sup2; is already included in the base price.</p>
            <div class="qf-options qf-options--checks">
              <label class="qf-option"><input type="checkbox" name="extra" value="shed_small" data-price="75"><span>Shed or workshop <strong>under 50&nbsp;m&sup2;</strong><small>+ $75 &middot; e.g. 6&times;6&nbsp;m colourbond</small></span></label>
              <label class="qf-option"><input type="checkbox" name="extra" value="shed_large" data-price="120"><span>Shed or workshop <strong>50&ndash;100&nbsp;m&sup2;</strong><small>+ $120 &middot; e.g. multi-bay garage</small></span></label>
              <label class="qf-option qf-option--quote"><input type="checkbox" name="extra" value="shed_huge"><span>Shed or workshop <strong>over 100&nbsp;m&sup2;</strong><small>routes to custom quote</small></span></label>
              <label class="qf-option"><input type="checkbox" name="extra" value="granny" data-price="120"><span>Granny flat or secondary dwelling<small>+ $120</small></span></label>
              <label class="qf-option"><input type="checkbox" name="extra" value="pool" data-price="75"><span>In-ground swimming pool<small>+ $75 &middot; visual safety-barrier observation only</small></span></label>
            </div>
            <div class="qf-nav">
              <button type="button" class="qf-back" data-action="back">&larr; Back</button>
              <button type="button" class="btn btn--primary qf-next" data-action="next">Next &rarr;</button>
            </div>
          </fieldset>

          <!-- ===== Step 5: location ===== -->
          <fieldset class="qf-step" data-step="5">
            <legend class="qf-step__title">Where's the property?</legend>
            <p class="qf-help">Enter the address &mdash; I&rsquo;ll work out the distance from Mildura. If lookup fails, just pick the distance band manually.</p>

            <div class="qf-address-row">
              <input type="text" name="address" id="addressInput" class="qf-input" placeholder="e.g. 12 Riverside Drive, Mildura VIC 3500" autocomplete="street-address">
              <button type="button" class="btn btn--ghost qf-address-btn" id="addressCheckBtn">Check</button>
            </div>
            <p id="addressStatus" class="qf-address-status" aria-live="polite"></p>

            <div id="addressResult" class="qf-address-result" hidden>
              <div class="qf-address-summary">
                <p class="qf-address-distance"><strong id="addressDistanceLabel"></strong></p>
                <p class="qf-address-tier small" id="addressTierLabel"></p>
                <p class="qf-address-name small" id="addressNameLabel"></p>
              </div>
              <div class="qf-address-map">
                <iframe id="addressIframe" width="100%" height="220" style="border:0;display:block;" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Route from property to Mildura"></iframe>
              </div>
            </div>

            <div id="distanceManualWrap" class="qf-distance-manual">
              <p class="qf-distance-legend">
                <strong>Distance band</strong>
                <span id="distanceManualHint" class="qf-distance-hint">Auto-selects from your address &middot; tap to override</span>
              </p>
              <div class="qf-options">
                <label class="qf-option"><input type="radio" name="location" value="near" id="locationNear" required><span>0&ndash;15&nbsp;km<small>included</small></span></label>
                <label class="qf-option"><input type="radio" name="location" value="mid" id="locationMid"><span>16&ndash;27&nbsp;km<small>+ $50</small></span></label>
                <label class="qf-option qf-option--quote"><input type="radio" name="location" value="far" id="locationFar"><span>28&nbsp;km or more<small>custom quote</small></span></label>
              </div>
            </div>

            <div class="qf-nav">
              <button type="button" class="qf-back" data-action="back">&larr; Back</button>
              <button type="button" class="btn btn--primary qf-next" data-action="next" disabled>Next &rarr;</button>
            </div>
          </fieldset>

          <!-- ===== Step 6: additional notes ===== -->
          <fieldset class="qf-step" data-step="6">
            <legend class="qf-step__title">Anything I should know?</legend>
            <p class="qf-help">Optional &mdash; flag specific concerns, awkward access, or anything you&rsquo;ve already noticed at the property. I&rsquo;ll pay extra attention to these on the day.</p>
            <textarea
              name="notes"
              id="notesInput"
              class="qf-input qf-textarea"
              rows="5"
              placeholder="e.g. concerns about cracks in plaster around the lounge windows, suspect dampness in the back bedroom, agent mentioned the roof was redone in 2018."
              maxlength="1200"
            ></textarea>
            <p class="small qf-help-foot"><span id="notesCount">0</span> / 1200 characters</p>
            <div class="qf-nav">
              <button type="button" class="qf-back" data-action="back">&larr; Back</button>
              <button type="button" class="btn btn--primary qf-next" data-action="next">Review &rarr;</button>
            </div>
          </fieldset>

          <!-- ===== Step 7: property summary ===== -->
          <fieldset class="qf-step qf-step--summary" data-step="7">
            <legend class="qf-step__title">Property Summary</legend>
            <p class="qf-help">Everything look right? Hit continue to pick a time.</p>

            <ul id="reviewLines" class="qf-review"></ul>

            <div class="qf-review-total" id="reviewTotalWrap">
              <span class="qf-review-total__label">Total</span>
              <span class="qf-review-total__amount" id="reviewTotal">$495</span>
              <span class="qf-review-total__inc">inc. GST</span>
            </div>

            <p class="small qf-quote-hint" id="quoteHint" style="display:none;">
              Some answers need a custom quote &mdash; we&rsquo;ll route you to email after submission.
            </p>

            <div class="qf-nav">
              <button type="button" class="qf-back" data-action="back">&larr; Back</button>
              <button type="submit" class="btn btn--primary btn--lg qf-submit" id="continueBtn">
                <span class="continueLabel">Continue to choose a date &rarr;</span>
              </button>
            </div>
          </fieldset>

        </form>
      </div>

      <!-- ============ STEP 2: CALENDAR ============ -->
      <div id="step2" class="step-hidden" aria-hidden="true">
        <div class="step2-head">
          <h2 class="h-3 mb-2 mt-5">Pick a date and time</h2>
          <button type="button" class="btn-link" id="editAnswersBtn">&larr; Edit my answers</button>
        </div>
        <p class="small mb-3" style="color:var(--mid);">
          Cal.com calendar below. Your property summary is pre-filled into the booking notes so I see what I&rsquo;m turning up to.
        </p>

        <div id="cal-inline" class="cal-embed"></div>

        <p class="small mt-3" style="color:var(--mid);">
          Can&rsquo;t see a slot that works? Urgent same-day or weekend slots may be available with a $150 surcharge &mdash; email <a href="mailto:inspections@wayfarecon.com"><strong>inspections@wayfarecon.com</strong></a> with the property address and preferred date.
        </p>
      </div>

      <!-- ============ QUOTE PATH ============ -->
      <div id="quotePath" class="step-hidden" aria-hidden="true">
        <div class="quote-card">
          <h2 class="h-3 mb-2">This one needs a custom quote</h2>
          <p>Based on your answers, your inspection falls outside the standard pricing tiers (typically larger sheds, very large homes, or properties 28&nbsp;km or more from Mildura). I&rsquo;ll quote you within a few hours.</p>
          <p class="small" style="color:var(--mid); margin-top: var(--space-3);">Your property summary is included in the email below &mdash; just hit send.</p>
          <a href="#" class="btn btn--primary btn--lg" id="emailQuoteBtn" style="margin-top: var(--space-4);">Email me a custom quote &rarr;</a>
        </div>
      </div>

    </div>
  </section>

  <section style="background:var(--cream);">
    <div class="wrap">
      <h2 class="h-3 mb-3">How payment works</h2>
      <p class="lede mb-4" style="max-width:65ch;">No deposit at booking. You pay once the inspection is done and before I release the report &mdash; keeps everything simple and fair.</p>

      <div class="payment-steps">
        <div class="payment-step">
          <span class="payment-step__num">01</span>
          <h3 class="payment-step__title">Answer the questions</h3>
          <p>Quick five-question quiz gives you a transparent price up front.</p>
        </div>
        <div class="payment-step">
          <span class="payment-step__num">02</span>
          <h3 class="payment-step__title">Pick your slot</h3>
          <p>Calendar shows my real availability &mdash; no back-and-forth.</p>
        </div>
        <div class="payment-step">
          <span class="payment-step__num">03</span>
          <h3 class="payment-step__title">I inspect the property</h3>
          <p>You don&rsquo;t need to be there. Every system, every room &mdash; I take the time the property needs.</p>
        </div>
        <div class="payment-step">
          <span class="payment-step__num">04</span>
          <h3 class="payment-step__title">I write the report</h3>
          <p>Photo-rich, plain English. Within 24 hours of the inspection.</p>
        </div>
        <div class="payment-step">
          <span class="payment-step__num">05</span>
          <h3 class="payment-step__title">Tax invoice &amp; report</h3>
          <p>Pay by bank transfer or PayID. Report released the moment payment lands.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ============ Cal.com inline embed loader ============ -->
  <script is:inline>
    let calBooted = false;
    function bootCal () {
      if (calBooted) return;
      calBooted = true;
      (function (C, A, L) {
        let p = function (a, ar) { a.q.push(ar); };
        let d = C.document;
        C.Cal = C.Cal || function () {
          let cal = C.Cal;
          let ar = arguments;
          if (!cal.loaded) {
            cal.ns = {};
            cal.q = cal.q || [];
            d.head.appendChild(d.createElement("script")).src = A;
            cal.loaded = true;
          }
          if (ar[0] === L) {
            const api = function () { p(api, arguments); };
            const namespace = ar[1];
            api.q = api.q || [];
            if (typeof namespace === "string") {
              cal.ns[namespace] = cal.ns[namespace] || api;
              p(cal.ns[namespace], ar);
              p(cal, ["initNamespace", namespace]);
            } else p(cal, ar);
            return;
          }
          p(cal, ar);
        };
      })(window, "https://app.cal.com/embed/embed.js", "init");

      Cal("init", "wayfare-inspection", { origin: "https://app.cal.com" });
      Cal.ns["wayfare-inspection"]("inline", {
        elementOrSelector: "#cal-inline",
        config: {
          layout: "month_view",
          useSlotsViewOnSmallScreen: "true",
          notes: window.__wayfareBookingNotes || ""
        },
        calLink: "wayfare-inspections/pre-purchase-building-inspection",
      });
      Cal.ns["wayfare-inspection"]("ui", {
        hideEventTypeDetails: false,
        layout: "month_view",
        styles: { branding: { brandColor: "#B5472D" } }
      });
    }
  </script>

  <!-- ============ Address geocoding (OpenStreetMap / Nominatim) ============ -->
  <script is:inline>
    (function () {
      const MILDURA_CBD = { lat: -34.1850, lon: 142.1625 };

      const addressInput   = document.getElementById('addressInput');
      const checkBtn       = document.getElementById('addressCheckBtn');
      const statusEl       = document.getElementById('addressStatus');
      const resultEl       = document.getElementById('addressResult');
      const distanceLabel  = document.getElementById('addressDistanceLabel');
      const tierLabel      = document.getElementById('addressTierLabel');
      const nameLabel      = document.getElementById('addressNameLabel');
      const mapIframe      = document.getElementById('addressIframe');
      const distanceHint   = document.getElementById('distanceManualHint');
      const locationNear   = document.getElementById('locationNear');
      const locationMid    = document.getElementById('locationMid');
      const locationFar    = document.getElementById('locationFar');

      function haversineKm (a, b) {
        const R = 6371;
        const toRad = function (d) { return d * Math.PI / 180; };
        const dLat = toRad(b.lat - a.lat);
        const dLon = toRad(b.lon - a.lon);
        const x = Math.sin(dLat/2) ** 2 +
                  Math.cos(toRad(a.lat)) * Math.cos(toRad(b.lat)) *
                  Math.sin(dLon/2) ** 2;
        return R * 2 * Math.atan2(Math.sqrt(x), Math.sqrt(1 - x));
      }

      function tierForKm (km) {
        if (km <= 15) return { value: 'near', label: 'Included in base price (0–15 km from Mildura)' };
        if (km <= 27) return { value: 'mid',  label: 'Adds $50 (16–27 km from Mildura)' };
        return                 { value: 'far',  label: 'Custom quote (28 km+ from Mildura)' };
      }

      function setLocationRadio (value) {
        locationNear.checked = (value === 'near');
        locationMid.checked  = (value === 'mid');
        locationFar.checked  = (value === 'far');
        const evt = new Event('change', { bubbles: true });
        locationNear.dispatchEvent(evt);
      }

      function clearLocationRadio () {
        locationNear.checked = false;
        locationMid.checked  = false;
        locationFar.checked  = false;
        const evt = new Event('change', { bubbles: true });
        addressInput.dispatchEvent(evt);
      }

      function showManualFallback (message) {
        statusEl.textContent = message + ' Pick the band below instead.';
        statusEl.className = 'qf-address-status qf-address-status--warn';
        resultEl.hidden = true;
        distanceHint.textContent = 'Pick the band manually below';
        addressInput.classList.remove('qf-input--ok');
        clearLocationRadio();
      }

      function showResult (km, place) {
        const tier = tierForKm(km);
        const rounded = km < 10 ? km.toFixed(1) : Math.round(km).toString();
        distanceLabel.textContent = rounded + ' km from Mildura CBD (straight line)';
        tierLabel.textContent = tier.label;
        nameLabel.textContent = place.displayName;

        const src =
          'https://maps.google.com/maps?saddr=' + encodeURIComponent(place.lat + ',' + place.lon) +
          '&daddr=' + encodeURIComponent(MILDURA_CBD.lat + ',' + MILDURA_CBD.lon) +
          '&output=embed';
        mapIframe.src = src;

        resultEl.hidden = false;
        statusEl.textContent = '✓ Address confirmed';
        statusEl.className = 'qf-address-status qf-address-status--ok';
        distanceHint.textContent = 'Auto-selected from your address · tap to override';
        addressInput.classList.add('qf-input--ok');
        setLocationRadio(tier.value);
      }

      let inflight = null;
      async function lookup () {
        const q = addressInput.value.trim();
        if (q.length < 6) {
          statusEl.textContent = 'Enter a full street address to check.';
          statusEl.className = 'qf-address-status qf-address-status--warn';
          return;
        }

        statusEl.textContent = 'Checking address…';
        statusEl.className = 'qf-address-status';
        checkBtn.disabled = true;

        const query = q + (q.toLowerCase().indexOf('australia') === -1 ? ', Australia' : '');
        const url = 'https://nominatim.openstreetmap.org/search?format=json&countrycodes=au&limit=1&q=' +
                    encodeURIComponent(query);

        try {
          if (inflight) inflight.abort();
          inflight = new AbortController();
          const r = await fetch(url, {
            headers: { 'Accept': 'application/json' },
            signal: inflight.signal,
          });
          const data = await r.json();
          inflight = null;
          checkBtn.disabled = false;

          if (!Array.isArray(data) || data.length === 0) {
            showManualFallback('We couldn’t find that address. Double-check the spelling, or pick the distance band below.');
            return;
          }

          const place = {
            lat: parseFloat(data[0].lat),
            lon: parseFloat(data[0].lon),
            displayName: data[0].display_name,
          };
          const km = haversineKm(MILDURA_CBD, place);

          if (km > 200) {
            showManualFallback('That address is over 200 km from Mildura — please check, or pick the band below.');
            return;
          }

          showResult(km, place);
        } catch (err) {
          if (err.name === 'AbortError') return;
          checkBtn.disabled = false;
          showManualFallback('Couldn’t reach the address lookup right now. Pick the distance band below.');
        }
      }

      checkBtn.addEventListener('click', lookup);

      addressInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); lookup(); }
      });

      let debounce = null;
      addressInput.addEventListener('input', function () {
        clearTimeout(debounce);
        if (!resultEl.hidden) {
          resultEl.hidden = true;
          addressInput.classList.remove('qf-input--ok');
          statusEl.textContent = '';
          statusEl.className = 'qf-address-status';
          distanceHint.textContent = 'Auto-selects from your address · tap to override';
          clearLocationRadio();
        }
        debounce = setTimeout(function () {
          if (addressInput.value.trim().length >= 8) lookup();
        }, 1500);
      });

      [locationNear, locationMid, locationFar].forEach(function (r) {
        r.addEventListener('click', function () {
          if (!resultEl.hidden) {
            distanceHint.textContent = 'Manual override active';
          }
        });
      });
    })();
  </script>

  <!-- ============ Step navigation + quote calculator ============ -->
  <script is:inline>
    (function () {
      const BASE_PRICE = 495;
      const AUTO_QUOTE_CAP = 900;
      const TOTAL_STEPS = 6;          /* 6 question steps; the final step is the Property Summary */

      const form = document.getElementById('quoteForm');
      const steps = Array.prototype.slice.call(form.querySelectorAll('.qf-step'));
      const stepCurrentEl = document.getElementById('stepCurrent');
      const stepTotalEl = document.getElementById('stepTotal');
      if (stepTotalEl) stepTotalEl.textContent = TOTAL_STEPS;
      const progressBarEl = document.getElementById('progressBar');
      const progressPriceEl = document.getElementById('progressPrice');
      const reviewLinesEl = document.getElementById('reviewLines');
      const reviewTotalEl = document.getElementById('reviewTotal');
      const reviewTotalWrap = document.getElementById('reviewTotalWrap');
      const continueBtn = document.getElementById('continueBtn');
      const continueLabel = continueBtn.querySelector('.continueLabel');
      const quoteHint = document.getElementById('quoteHint');
      const step1Block = document.getElementById('step1');
      const step2Block = document.getElementById('step2');
      const quotePath = document.getElementById('quotePath');
      const editBtn = document.getElementById('editAnswersBtn');
      const emailQuoteBtn = document.getElementById('emailQuoteBtn');

      let currentStep = 1;
      const TOTAL_QUIZ_STEPS = steps.length;  /* 6 = 5 questions + review */

      function goToStep (n, opts) {
        opts = opts || {};
        currentStep = Math.max(1, Math.min(TOTAL_QUIZ_STEPS, n));
        steps.forEach(function (el) {
          const s = parseInt(el.getAttribute('data-step'), 10);
          el.classList.toggle('is-active', s === currentStep);
        });
        const displayed = Math.min(currentStep, TOTAL_STEPS);
        stepCurrentEl.textContent = displayed;
        progressBarEl.style.width = (Math.min(currentStep / TOTAL_STEPS, 1) * 100) + '%';
        if (currentStep === TOTAL_QUIZ_STEPS) {
          buildReview();
        }
        if (!opts.silent) {
          // Scroll the form into view but a bit below the sticky header
          const wrap = form.getBoundingClientRect();
          if (wrap.top < 0 || wrap.top > 140) {
            form.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
        // Move focus to the new step's first focusable element for accessibility
        const active = form.querySelector('.qf-step.is-active');
        if (active && !opts.silent) {
          const firstInput = active.querySelector('input, button');
          if (firstInput) setTimeout(function () { firstInput.focus({ preventScroll: true }); }, 250);
        }
      }

      function stepEl (n) {
        return form.querySelector('.qf-step[data-step="' + n + '"]');
      }

      function stepIsValid (n) {
        const el = stepEl(n);
        if (!el) return false;
        if (n === 1) return !!form.querySelector('input[name="bedrooms"]:checked');
        if (n === 2) return !!form.querySelector('input[name="storeys"]:checked');
        if (n === 3) return !!form.querySelector('input[name="foundation"]:checked');
        if (n === 4) return true; /* extras are optional */
        if (n === 5) return !!form.querySelector('input[name="location"]:checked');
        if (n === 6) return true; /* notes are optional */
        if (n === 7) return calc().formValid;
        return false;
      }

      function refreshStepNavState (n) {
        const el = stepEl(n);
        if (!el) return;
        const nextBtn = el.querySelector('[data-action="next"], .qf-submit');
        if (!nextBtn) return;
        if (n === 4 || n === 6) { nextBtn.disabled = false; return; } /* extras and notes are optional */
        nextBtn.disabled = !stepIsValid(n);
      }

      function refreshAllNav () {
        for (let i = 1; i <= TOTAL_QUIZ_STEPS; i++) refreshStepNavState(i);
      }

      function calc () {
        const fd = new FormData(form);
        let total = BASE_PRICE;
        let quoteRequired = false;
        const lines = [];

        const beds = fd.get('bedrooms');
        if (beds === 'medium') { total += 70; lines.push({ k: 'Size', v: '4–5 bedrooms', d: '+ $70' }); }
        else if (beds === 'quote') { quoteRequired = true; lines.push({ k: 'Size', v: '6+ bedrooms', d: 'quote' }); }
        else if (beds === 'small') { lines.push({ k: 'Size', v: '1–3 bedrooms', d: 'included' }); }

        const sto = fd.get('storeys');
        if (sto === 'double') { total += 90; lines.push({ k: 'Storeys', v: 'Double / split-level', d: '+ $90' }); }
        else if (sto === 'single') { lines.push({ k: 'Storeys', v: 'Single', d: 'included' }); }

        const fnd = fd.get('foundation');
        if (fnd === 'stumps') { total += 90; lines.push({ k: 'Foundation', v: 'Stumps / piers', d: '+ $90' }); }
        else if (fnd === 'slab') { lines.push({ k: 'Foundation', v: 'Slab on ground', d: 'included' }); }
        else if (fnd === 'unsure') { lines.push({ k: 'Foundation', v: 'Not sure — confirm on site', d: '' }); }

        const extras = fd.getAll('extra');
        if (extras.length === 0) {
          lines.push({ k: 'Extras', v: 'None', d: '' });
        } else {
          extras.forEach(function (val) {
            if (val === 'shed_small') { total += 75; lines.push({ k: 'Extras', v: 'Shed under 50 m²', d: '+ $75' }); }
            else if (val === 'shed_large') { total += 120; lines.push({ k: 'Extras', v: 'Shed 50–100 m²', d: '+ $120' }); }
            else if (val === 'shed_huge') { quoteRequired = true; lines.push({ k: 'Extras', v: 'Shed over 100 m²', d: 'quote' }); }
            else if (val === 'granny') { total += 120; lines.push({ k: 'Extras', v: 'Granny flat', d: '+ $120' }); }
            else if (val === 'pool') { total += 75; lines.push({ k: 'Extras', v: 'Pool', d: '+ $75' }); }
          });
        }

        const loc = fd.get('location');
        if (loc === 'far') { quoteRequired = true; lines.push({ k: 'Location', v: '28 km+ from Mildura', d: 'quote' }); }
        else if (loc === 'mid') { total += 50; lines.push({ k: 'Location', v: '16–27 km from Mildura', d: '+ $50' }); }
        else if (loc === 'near') { lines.push({ k: 'Location', v: '0–15 km from Mildura', d: 'included' }); }

        if (total > AUTO_QUOTE_CAP) quoteRequired = true;

        return {
          total: total,
          quoteRequired: quoteRequired,
          lines: lines,
          address: (fd.get('address') || '').toString().trim(),
          notes: (fd.get('notes') || '').toString().trim(),
          formValid: form.checkValidity()
        };
      }

      function renderPrice () {
        const r = calc();
        if (r.quoteRequired) {
          progressPriceEl.textContent = 'Custom quote';
        } else if (r.formValid) {
          progressPriceEl.textContent = '$' + r.total;
        } else if (r.total > BASE_PRICE) {
          progressPriceEl.textContent = '$' + r.total + '+';
        } else {
          progressPriceEl.textContent = 'from $495';
        }
      }

      function escapeHtml (s) {
        return s
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function buildReview () {
        const r = calc();
        reviewLinesEl.innerHTML = '';
        r.lines.forEach(function (line) {
          const li = document.createElement('li');
          li.className = 'qf-review__row';
          li.innerHTML =
            '<span class="qf-review__key">' + line.k + '</span>' +
            '<span class="qf-review__val">' + line.v + '</span>' +
            '<span class="qf-review__delta">' + (line.d || '') + '</span>';
          reviewLinesEl.appendChild(li);
        });
        if (r.address) {
          const li = document.createElement('li');
          li.className = 'qf-review__row qf-review__row--address';
          li.innerHTML =
            '<span class="qf-review__key">Address</span>' +
            '<span class="qf-review__val">' + escapeHtml(r.address) + '</span>' +
            '<span class="qf-review__delta"></span>';
          reviewLinesEl.appendChild(li);
        }
        if (r.notes) {
          const li = document.createElement('li');
          li.className = 'qf-review__row qf-review__row--notes';
          li.innerHTML =
            '<span class="qf-review__key">Notes</span>' +
            '<span class="qf-review__val">' + escapeHtml(r.notes) + '</span>' +
            '<span class="qf-review__delta"></span>';
          reviewLinesEl.appendChild(li);
        }
        if (r.quoteRequired) {
          reviewTotalEl.textContent = 'Custom quote';
          reviewTotalWrap.classList.add('qf-review-total--quote');
          continueLabel.textContent = 'Request a custom quote →';
          quoteHint.style.display = 'block';
        } else {
          reviewTotalEl.textContent = '$' + r.total;
          reviewTotalWrap.classList.remove('qf-review-total--quote');
          continueLabel.textContent = 'Continue to choose a date →';
          quoteHint.style.display = 'none';
        }
      }

      function summaryText () {
        const r = calc();
        const lines = [
          'PROPERTY SUMMARY',
          '----------------',
          r.address ? ('Address: ' + r.address) : 'Address: (provided in booking)',
          '',
          'Inspection details:',
        ];
        r.lines.forEach(function (l) {
          lines.push('• ' + l.k + ': ' + l.v + (l.d ? ' (' + l.d + ')' : ''));
        });
        if (r.notes) {
          lines.push('', "Customer's notes:", r.notes);
        }
        if (r.quoteRequired) {
          lines.push('', 'CUSTOM QUOTE REQUIRED');
        } else {
          lines.push('', 'CALCULATED PRICE: $' + r.total + ' inc. GST');
        }
        return lines.join('\n');
      }

      // ===== Navigation handlers =====
      form.addEventListener('click', function (e) {
        const t = e.target.closest('[data-action]');
        if (!t) return;
        const action = t.getAttribute('data-action');
        if (action === 'next') {
          if (!stepIsValid(currentStep)) return;
          goToStep(currentStep + 1);
        } else if (action === 'back') {
          goToStep(currentStep - 1);
        }
      });

      // ===== Input handlers =====
      // Every step requires an explicit Next click — no auto-advance.
      form.addEventListener('change', function () {
        renderPrice();
        refreshAllNav();
      });
      form.addEventListener('input', function (e) {
        renderPrice();
        refreshAllNav();
        // Live char counter for the notes textarea
        if (e.target && e.target.id === 'notesInput') {
          const counter = document.getElementById('notesCount');
          if (counter) counter.textContent = e.target.value.length;
        }
      });

      // ===== Submission from review step =====
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        const r = calc();
        if (!r.formValid) return;

        if (r.quoteRequired) {
          const body = encodeURIComponent(
            'Hi Acton,\n\nI’d like a custom quote for a pre-purchase building inspection.\n\n' +
            summaryText() + '\n\nName:\nBest contact number:\nIdeal inspection date:\n\nThanks.'
          );
          const subject = encodeURIComponent('Custom quote — pre-purchase building inspection');
          const mailto = 'mailto:inspections@wayfarecon.com?subject=' + subject + '&body=' + body;
          emailQuoteBtn.setAttribute('href', mailto);
          step1Block.classList.add('step-hidden');
          step1Block.setAttribute('aria-hidden', 'true');
          quotePath.classList.remove('step-hidden');
          quotePath.setAttribute('aria-hidden', 'false');
          quotePath.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else {
          window.__wayfareBookingNotes = summaryText();
          step1Block.classList.add('step-hidden');
          step1Block.setAttribute('aria-hidden', 'true');
          step2Block.classList.remove('step-hidden');
          step2Block.setAttribute('aria-hidden', 'false');
          bootCal();
          step2Block.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      editBtn.addEventListener('click', function () {
        step2Block.classList.add('step-hidden');
        step2Block.setAttribute('aria-hidden', 'true');
        step1Block.classList.remove('step-hidden');
        step1Block.setAttribute('aria-hidden', 'false');
        goToStep(TOTAL_QUIZ_STEPS); /* return to review */
      });

      // Initial paint
      goToStep(1, { silent: true });
      renderPrice();
      refreshAllNav();
    })();
  </script>

  <style>
    /* ============ Progress bar ============ */
    .qf-progress {
      position: sticky;
      top: 72px;
      z-index: 10;
      background: var(--ink);
      color: var(--cream);
      padding: 12px 16px;
      border-radius: 10px;
      margin-bottom: var(--space-4);
      box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    }
    .qf-progress__row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      font-size: 0.85rem;
    }
    .qf-progress__step {
      font-family: var(--font-mono, monospace);
      font-size: 0.75rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      opacity: 0.85;
    }
    .qf-progress__step strong { font-weight: 700; opacity: 1; color: var(--sandstone); }
    .qf-progress__price {
      font-family: "Archivo Black", sans-serif;
      font-size: 1.2rem;
      line-height: 1;
      letter-spacing: 0.01em;
    }
    .qf-progress__price small {
      font-family: var(--font-body, sans-serif);
      font-weight: 400;
      font-size: 0.7rem;
      opacity: 0.7;
      margin-left: 4px;
      letter-spacing: 0;
    }
    .qf-progress__bar {
      margin-top: 10px;
      height: 4px;
      background: rgba(245,239,227,0.18);
      border-radius: 99px;
      overflow: hidden;
    }
    .qf-progress__bar span {
      display: block;
      height: 100%;
      width: 20%;
      background: var(--mallee);
      border-radius: 99px;
      transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ============ Quote form / steps ============ */
    .quote-form { display: flex; flex-direction: column; }
    .qf-step {
      border: 0;
      padding: 0;
      margin: 0;
      display: none;
      flex-direction: column;
      gap: var(--space-3);
      animation: qfFade 0.28s ease both;
    }
    .qf-step.is-active { display: flex; }
    @keyframes qfFade {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .qf-step__title {
      font-family: var(--font-display, serif);
      font-weight: 500;
      font-size: clamp(1.4rem, 3vw, 1.8rem);
      line-height: 1.15;
      color: var(--ink);
      padding: 0;
      margin: 0;
    }
    .qf-help {
      font-size: 0.95rem;
      color: var(--mid);
      margin: 0;
      line-height: 1.5;
      max-width: 60ch;
    }
    .qf-options {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 10px;
      margin-top: 6px;
    }
    .qf-options--checks {
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    }
    .qf-option {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      background: #fff;
      border: 1.5px solid #e5e2dc;
      border-radius: 10px;
      padding: 14px 16px;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s, box-shadow 0.15s, transform 0.05s;
      line-height: 1.4;
      min-height: 56px;
    }
    .qf-option:hover { border-color: var(--mallee); }
    .qf-option:active { transform: scale(0.99); }
    .qf-option input { margin-top: 3px; accent-color: var(--mallee); cursor: pointer; width: 20px; height: 20px; flex: 0 0 auto; }
    .qf-option:has(input:checked) {
      border-color: var(--mallee);
      background: #fdf4f0;
      box-shadow: 0 0 0 2px rgba(181, 71, 45, 0.12);
    }
    .qf-option span {
      display: flex;
      flex-direction: column;
      font-size: 1rem;
      font-weight: 500;
      color: var(--ink);
    }
    .qf-option small {
      font-size: 0.8rem;
      color: var(--mid);
      font-weight: 400;
      margin-top: 2px;
    }
    .qf-option--quote {
      background: #faf6ef;
      border-style: dashed;
    }
    .qf-option--quote:has(input:checked) {
      background: #fdf4f0;
      border-style: solid;
    }
    .qf-input {
      width: 100%;
      padding: 14px 16px;
      border: 1.5px solid #e5e2dc;
      border-radius: 10px;
      font-size: 16px;            /* prevents iOS auto-zoom */
      font-family: inherit;
      background: #fff;
      color: var(--ink);
      min-height: 52px;
    }
    .qf-input:focus {
      outline: none;
      border-color: var(--mallee);
      box-shadow: 0 0 0 3px rgba(181, 71, 45, 0.12);
    }
    /* Hide placeholder text the moment the field is focused/clicked, before typing starts. */
    .qf-input:focus::placeholder,
    .qf-textarea:focus::placeholder { color: transparent; }
    .qf-input::placeholder, .qf-textarea::placeholder {
      color: #a39c8d;
      opacity: 1;
      transition: color 0.12s ease;
    }
    /* Textarea variant */
    .qf-textarea {
      resize: vertical;
      min-height: 140px;
      line-height: 1.5;
      padding-top: 14px;
    }
    .qf-help-foot {
      color: var(--mid);
      margin: 6px 0 0;
      text-align: right;
      font-variant-numeric: tabular-nums;
    }

    /* Address row */
    .qf-address-row {
      display: flex;
      gap: 10px;
      align-items: stretch;
    }
    .qf-address-row .qf-input { flex: 1 1 auto; }
    .qf-address-btn {
      flex: 0 0 auto;
      white-space: nowrap;
    }
    @media (max-width: 560px) {
      .qf-address-row { flex-direction: column; }
      .qf-address-btn { width: 100%; }
    }
    .qf-address-status {
      font-size: 0.9rem;
      color: var(--mid);
      margin: 8px 0 0;
      min-height: 1.3em;
    }
    .qf-address-status--warn { color: var(--mallee); }
    .qf-address-status--ok { color: #1d7a3a; font-weight: 600; }
    .qf-input.qf-input--ok {
      border-color: #1d7a3a;
      background: #f4faf6;
    }
    .qf-input.qf-input--ok:focus {
      box-shadow: 0 0 0 3px rgba(29, 122, 58, 0.12);
    }
    .qf-distance-legend {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-3);
      flex-wrap: wrap;
      margin: var(--space-4) 0 8px;
      font-family: var(--font-display, serif);
      font-size: 1.05rem;
    }
    .qf-distance-hint {
      font-family: inherit;
      font-size: 0.82rem;
      font-weight: 400;
      color: var(--mid);
    }
    .qf-address-result {
      margin-top: var(--space-3);
      background: var(--cream, #fdf8ef);
      border: 1px solid #e5e2dc;
      border-radius: 10px;
      overflow: hidden;
    }
    .qf-address-summary { padding: var(--space-3) var(--space-4); }
    .qf-address-distance {
      margin: 0;
      font-size: 1.05rem;
      color: var(--ink);
    }
    .qf-address-distance strong {
      font-family: var(--font-display, serif);
      font-weight: 700;
    }
    .qf-address-tier { margin: 4px 0 0; color: var(--mallee); font-weight: 600; }
    .qf-address-name { margin: 6px 0 0; color: var(--mid); line-height: 1.4; }
    .qf-address-map { border-top: 1px solid #e5e2dc; }
    .qf-address-map iframe { display: block; width: 100%; }

    /* ============ Step navigation buttons ============ */
    .qf-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-3);
      margin-top: var(--space-4);
    }
    .qf-nav .qf-back {
      background: none;
      border: 0;
      color: var(--mid);
      font-size: 0.95rem;
      font-weight: 500;
      cursor: pointer;
      padding: 12px 4px;
      text-decoration: none;
    }
    .qf-nav .qf-back:hover { color: var(--ink); }
    .qf-nav .qf-back[disabled] { opacity: 0; pointer-events: none; }
    .qf-nav .btn { min-width: 160px; }
    .qf-nav .btn[disabled] { opacity: 0.4; cursor: not-allowed; }
    .qf-nav .qf-submit { min-width: 220px; }

    /* ============ Review step ============ */
    /* Rules below use :global() because the row elements are built in JS via innerHTML
       and don't carry Astro's scoped class attribute. */
    .qf-step--summary { gap: var(--space-3); }
    .qf-review {
      list-style: none;
      padding: 0;
      margin: 0;
      border: 1px solid #e5e2dc;
      border-radius: 10px;
      background: #fff;
      overflow: hidden;
    }
    :global(.qf-review__row) {
      display: grid;
      grid-template-columns: 110px 1fr auto;
      gap: 14px;
      align-items: baseline;
      padding: 12px 14px;
      border-bottom: 1px solid #f1eee6;
    }
    :global(.qf-review__row:last-child) { border-bottom: 0; }
    :global(.qf-review__key) {
      font-family: var(--font-mono, monospace);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--mid);
    }
    :global(.qf-review__val) {
      font-size: 0.95rem;
      color: var(--ink);
      line-height: 1.4;
      word-break: break-word;
    }
    :global(.qf-review__delta) {
      font-family: var(--font-mono, monospace);
      font-size: 0.78rem;
      color: var(--mallee);
      white-space: nowrap;
    }
    :global(.qf-review__row--address .qf-review__val) {
      font-size: 0.88rem;
      color: var(--mid);
    }
    :global(.qf-review__row--notes .qf-review__val) {
      font-size: 0.9rem;
      color: var(--charcoal);
      white-space: pre-wrap;       /* preserve line breaks from textarea */
      line-height: 1.5;
    }
    .qf-review-total {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 10px;
      padding: 16px 18px;
      background: var(--mallee);
      color: var(--cream);
      border-radius: 10px;
    }
    .qf-review-total__label {
      font-family: var(--font-mono, monospace);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.85rem;
      opacity: 0.9;
    }
    .qf-review-total__amount {
      font-family: "Archivo Black", sans-serif;
      font-size: 2rem;
      line-height: 1;
      letter-spacing: 0.01em;
    }
    .qf-review-total__inc {
      font-size: 0.78rem;
      opacity: 0.85;
    }
    .qf-review-total--quote .qf-review-total__amount { font-size: 1.4rem; }

    .qf-quote-hint {
      color: var(--mid);
      margin: 0;
    }

    /* ============ Step transitions / containers ============ */
    .step-hidden { display: none !important; }
    .step2-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      flex-wrap: wrap;
    }
    .btn-link {
      background: none;
      border: 0;
      color: var(--mallee);
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      padding: 0;
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .btn-link:hover { color: var(--ink); }

    /* ============ Quote-path card ============ */
    .quote-card {
      background: var(--cream);
      border: 1px solid #e5e2dc;
      border-radius: 10px;
      padding: var(--space-5);
      margin-top: var(--space-5);
    }

    /* ============ Cal embed ============ */
    .cal-embed {
      width: 100%;
      min-height: 720px;
      background: #fff;
      border: 1px solid #e5e2dc;
      border-radius: 10px;
      overflow: hidden;
    }

    /* ============ Payment steps ============ */
    .payment-steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: var(--space-4);
      margin-top: var(--space-3);
    }
    .payment-step {
      background: #fff;
      border: 1px solid #e5e2dc;
      border-radius: 10px;
      padding: var(--space-4);
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .payment-step__num {
      font-family: var(--font-mono, monospace);
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--mallee);
      letter-spacing: 0.06em;
    }
    .payment-step__title {
      font-family: var(--font-display, serif);
      font-size: 1.1rem;
      font-weight: 600;
      margin: 0;
      line-height: 1.3;
    }
    .payment-step p {
      margin: 0;
      font-size: 0.95rem;
      line-height: 1.55;
      color: var(--mid, #555);
    }

    /* ============ Mobile tweaks ============ */
    @media (max-width: 760px) {
      .qf-progress {
        top: 56px;
        padding: 10px 12px;
        border-radius: 8px;
      }
      .qf-progress__price { font-size: 1.1rem; }
      .cal-embed { min-height: 720px; border-radius: 8px; }
      .qf-options, .qf-options--checks { grid-template-columns: 1fr; }
      .qf-step__title { font-size: 1.35rem; }
      .qf-address-map iframe { height: 200px; }
      .qf-nav { flex-direction: column-reverse; align-items: stretch; gap: 8px; }
      .qf-nav .btn, .qf-nav .qf-submit { width: 100%; min-width: 0; }
      .qf-nav .qf-back { text-align: center; padding: 12px; }
      .qf-review__row {
        grid-template-columns: 90px 1fr auto;
        padding: 10px 12px;
      }
      .qf-review__key { font-size: 0.65rem; }
      .qf-review__val { font-size: 0.92rem; }
      .qf-review-total { padding: 14px 16px; }
      .qf-review-total__amount { font-size: 1.7rem; }
    }
  </style>
</BaseLayout>
