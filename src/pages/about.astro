---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'About Acton — licensed builder, inspector, Mildura local';
const description = 'Wayfare Construction Inspections is run by Acton Hill-Ford, a licensed builder born and raised in Mildura. Here is why I started doing inspections.';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Acton Hill-Ford',
  jobTitle: 'Licensed Builder & Inspector',
  worksFor: { '@type': 'Organization', name: 'Wayfare Construction Inspections' },
  hasCredential: [
    { '@type': 'EducationalOccupationalCredential', name: 'Domestic Builder Unlimited DB-U 100124 (individual)' },
    { '@type': 'EducationalOccupationalCredential', name: 'Domestic Builder Unlimited CDB-U 100482 (company)' },
    { '@type': 'EducationalOccupationalCredential', name: 'Certificate IV in Building & Construction CPC40110' },
    { '@type': 'EducationalOccupationalCredential', name: 'Qualified Carpenter' },
  ],
};
---
<BaseLayout title={title} description={description} schema={[personSchema]}>
  <section class="hero hero--inner">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a><span>·</span>About</p>
      <h1>I'm Acton — a registered builder with 17 years in construction.</h1>
      <p class="lede">Wayfare Construction Inspections is a one-person business by design. I do the inspection, I write the report, I answer the phone. There's nobody to escalate to and nobody who doesn't know your job.</p>
    </div>
  </section>

  <section>
    <div class="wrap wrap--narrow">
      <h2 class="h-2 mb-3">17 years on the tools</h2>
      <p>Across 17 years I've worked residential jobs across Australia and New Zealand — first as a qualified carpenter, more recently as a registered builder. New builds, extensions, kitchens, bathrooms, restorations, outdoor entertaining — the whole domestic spectrum.</p>
      <p>Mildura is home. I came back to the region years ago and I've been building here ever since.</p>

      <h2 class="h-2 mt-5 mb-3">Why inspections, why now</h2>
      <p>The reason I started Wayfare Construction Inspections is honest: too many buyers in Mildura were ending up with a property that had problems no-one had told them about. Some had paid for an inspection. Some hadn't. Either way the report didn't catch what an experienced builder would have caught in fifteen minutes on site.</p>
      <p>Pre-purchase inspections done well are a service this town needs. So that's what Wayfare is — one licensed builder, doing one service, very carefully.</p>

      <h2 class="h-2 mt-5 mb-3">Qualifications</h2>
      <ul style="list-style:none;padding:0;display:grid;gap:var(--space-2);font-family:var(--font-mono);font-size:14px;">
        <li><strong>DB-U 100124</strong> · Domestic Builder unlimited (individual)</li>
        <li><strong>CDB-U 100482</strong> · Domestic Builder unlimited (company)</li>
        <li><strong>CPC40110</strong> · Certificate IV in Building &amp; Construction</li>
        <li><strong>Qualified Carpenter</strong> · Time-served trade</li>
        <li>Member · Master Builders Association of Victoria / HIA</li>
        <li>Professional Indemnity + Public Liability insurance &middot; Australia-wide cover</li>
        <li>Reports prepared in accordance with AS&nbsp;4349.1</li>
      </ul>

      <h2 class="h-2 mt-5 mb-3">The promise</h2>
      <ol class="steps">
        <li><strong>I do the inspection.</strong> No subcontracting, no junior inspector. It is me on site, every time.</li>
        <li><strong>I write the report.</strong> No template-stuffer or report-writing service. The words in your report are the words I'd use to explain it to my own family.</li>
        <li><strong>I deliver within 24 hours.</strong> The full written report lands in your inbox the day after I'm on site — usually sooner.</li>
        <li><strong>I do not upsell to my own building business.</strong> If you need repair quotes, I'll point you toward independent trades, not myself.</li>
      </ol>

      <div class="mt-5 center">
        <a href="/book/" class="btn btn--primary btn--lg">Book an inspection</a>
      </div>
    </div>
  </section>
</BaseLayout>
