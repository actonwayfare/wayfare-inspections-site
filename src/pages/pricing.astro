---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Pricing — pre-purchase building inspections in Mildura';
const description = 'Transparent pricing for pre-purchase building inspections in Mildura. $550 inc. GST. Booking and payment online.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://inspections.wayfarecon.com/' },
    { '@type': 'ListItem', position: 2, name: 'Pricing', item: 'https://inspections.wayfarecon.com/pricing/' },
  ],
};
---
<BaseLayout title={title} description={description} schema={[breadcrumb]}>
  <section class="hero hero--inner">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a><span>·</span>Pricing</p>
      <h1>Honest pricing. No quotes, no surprises.</h1>
      <p class="lede">Most building inspectors hide their pricing behind an enquiry form so they can quote each job. We publish ours because we'd rather you decided in two minutes than two days.</p>
    </div>
  </section>

  <section>
    <div class="wrap wrap--narrow">
      <div class="price-tier featured" style="text-align:center;">
        <h3>Pre-purchase building inspection</h3>
        <p class="price">$550 <small>inc. GST</small></p>
        <p class="small">For a typical Mildura home — three to four bedrooms, single storey, easy access.</p>
        <ul style="text-align:left;">
          <li>Full inspection to AS 4349.1</li>
          <li>40–60 page photo-rich PDF report</li>
          <li>Severity ratings on every finding</li>
          <li>Report delivered within 24 hours</li>
        </ul>
        <a href="/book/" class="btn btn--primary btn--full">Book an inspection</a>
      </div>

      <div class="card mt-4" style="border-style:dashed;">
        <p class="eyebrow" style="color:var(--mid);">Coming soon</p>
        <h3 class="h-3 mb-2">Building + pest combined</h3>
        <p class="small">A combined building and pest inspection in a single coordinated visit, in partnership with a licensed pest specialist. Launching shortly — <a href="/contact/">register interest</a> if it's relevant to your purchase.</p>
      </div>

      <hr class="divider" />

      <h2 class="h-2">What might cost extra</h2>
      <p>Most jobs are priced at $550 inc. GST. The exceptions, quoted upfront before you book:</p>
      <ul style="list-style:none;padding:0;display:grid;gap:var(--space-2);margin:var(--space-3) 0;">
        <li>• Rural properties on large blocks (over 1 acre, outbuildings, sheds, water tanks) — typically $100–$200 extra</li>
        <li>• Large homes (5+ bedrooms, double-storey, multiple living areas) — typically $100 extra</li>
        <li>• Urgent same-day or weekend turnaround — typically $150 extra, subject to availability</li>
        <li>• Properties more than 60 minutes from Mildura — quoted on enquiry</li>
      </ul>

      <h2 class="h-2 mt-5">Why we publish prices</h2>
      <p>It's simple. You're buying a house — possibly the biggest purchase of your life. The last thing you need is to be ringing three inspectors for quotes the week your cooling-off period closes. Published pricing means you know what to budget for and can book the moment you need it.</p>
      <p>If a job genuinely needs a different price (large rural property, urgent weekend, that sort of thing), I'll tell you on the booking page — never after.</p>

      <h2 class="h-2 mt-5">How payment works</h2>
      <p>No card required at booking. You secure your slot, I conduct the inspection, then I send a tax invoice. Your report is released the moment the invoice is paid — usually within hours.</p>

      <div class="mt-5 center">
        <a href="/book/" class="btn btn--primary btn--lg">Book an inspection</a>
      </div>
    </div>
  </section>
</BaseLayout>
