---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Pre-purchase building inspections in Mildura and Sunraysia';
const description = 'A full structural and aesthetic inspection by a licensed builder. Photo-rich, plain-English report delivered within 24 hours. Book online — $550 inc. GST.';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Pre-purchase building inspection',
  serviceType: 'Pre-purchase building inspection',
  provider: { '@id': 'https://inspections.wayfarecon.com/#business' },
  areaServed: { '@type': 'Place', name: 'Mildura and surrounds' },
  offers: { '@type': 'Offer', priceCurrency: 'AUD', price: '550', availability: 'https://schema.org/InStock' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://inspections.wayfarecon.com/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://inspections.wayfarecon.com/services/' },
    { '@type': 'ListItem', position: 3, name: 'Pre-purchase building inspection', item: 'https://inspections.wayfarecon.com/services/pre-purchase-building-inspection/' },
  ],
};
---
<BaseLayout title={title} description={description} schema={[serviceSchema, breadcrumbSchema]}>

  <section class="hero hero--inner">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a><span>·</span><a href="/services/">Services</a><span>·</span>Pre-purchase building inspection</p>
      <h1>{title}</h1>
      <p class="lede">A complete inspection of the property you're about to buy, by a licensed builder who has spent fifteen years putting houses together. You'll know what you're buying before you sign.</p>
      <div class="actions mt-4">
        <a href="/book/" class="btn btn--primary btn--lg">Book an inspection</a>
        <a href="/sample-report/" class="btn btn--ghost-cream btn--lg">See sample report</a>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap wrap--narrow">
      <p class="eyebrow">What it is</p>
      <h2 class="h-2 mb-3">What's a pre-purchase building inspection?</h2>
      <p>It's an independent, structural and aesthetic inspection of a property you're considering buying, conducted before you sign the contract or before cooling-off ends. The point is to flag any defects, safety concerns or expensive surprises so you can negotiate, walk away, or buy with both eyes open.</p>
      <p>The Wayfare report is prepared to <strong>AS 4349.1</strong>, the Australian standard for pre-purchase property inspections. You can show it to your conveyancer, your lender, or a builder for repair quotes — it's a properly weighted, professionally written document.</p>
    </div>
  </section>

  <section class="alt">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">What's covered</p>
        <h2 class="h-2">What I inspect</h2>
        <p class="lede">Every system, every room, top to bottom. Here's what gets eyes, hands and (where needed) a torch, ladder or moisture meter on it.</p>
      </div>
      <div class="grid grid--2">
        <div class="card">
          <h4>Structural elements</h4>
          <p>Foundations, slab, framing, walls, floors, ceilings, roof structure, sub-floor where accessible. Looking for movement, cracking, sagging, deflection, water damage.</p>
        </div>
        <div class="card">
          <h4>Exterior</h4>
          <p>Cladding, brickwork, render, paint, eaves, gutters and downpipes, driveways, paths, fencing. Looking for weathering, separation, water management, decay.</p>
        </div>
        <div class="card">
          <h4>Roof &amp; roof void</h4>
          <p>Tiles or sheeting, flashings, ridge capping, soffits. Inside the roof space — insulation, sarking, framing, signs of leaks, vermin or compromised structure.</p>
        </div>
        <div class="card">
          <h4>Interior</h4>
          <p>Every room. Floors, walls, ceilings, joinery, doors and windows, wet areas. Visual check of finishes, paint, levelness, evidence of movement or moisture.</p>
        </div>
        <div class="card">
          <h4>Wet areas</h4>
          <p>Bathrooms, ensuites, laundry, kitchen. Tile condition, grout, sealant, evidence of failed waterproofing, fixture condition.</p>
        </div>
        <div class="card">
          <h4>Sub-floor &amp; services (visual)</h4>
          <p>Sub-floor ventilation, evidence of moisture or movement, accessible plumbing and electrical (visual only — not testing). Hot water unit age and condition.</p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap wrap--narrow">
      <p class="eyebrow">Honest scope</p>
      <h2 class="h-2 mb-3">What's NOT covered (and what to do instead)</h2>
      <p>A pre-purchase building inspection is a visual, non-invasive assessment. It is not the same as:</p>
      <ul style="list-style:none;padding:0;display:grid;gap:var(--space-3);margin:var(--space-3) 0;">
        <li><strong style="font-family:var(--font-display);">Timber pest inspection</strong> &mdash; that's a separate report by a licensed pest specialist. A combined building + pest service in partnership with a local pest specialist is launching shortly &mdash; until then we recommend booking your pest inspection directly with a licensed pest specialist.</li>
        <li><strong style="font-family:var(--font-display);">Compliance certification</strong> &mdash; we don't certify works, we don't approve renovations, we don't sign off on the BCA.</li>
        <li><strong style="font-family:var(--font-display);">Electrical or plumbing testing</strong> &mdash; we visually inspect. If a fixture or circuit needs testing, that requires a licensed sparkie or plumber.</li>
        <li><strong style="font-family:var(--font-display);">Hidden defects behind plasterboard, in cavities or under floor coverings</strong> &mdash; if it can't be seen without invasive work, it can't be reported. Where we suspect a hidden issue, we'll flag it and recommend further investigation.</li>
      </ul>
      <p>This is an industry standard, not a Wayfare-specific limit. We are upfront about scope because we'd rather you understand the report than be disappointed by it.</p>
    </div>
  </section>

  <section class="alt">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">The deliverable</p>
        <h2 class="h-2">The report you receive</h2>
      </div>
      <div class="grid grid--3">
        <div class="card card--feature">
          <p class="eyebrow">Format</p>
          <h4>40–60 page PDF</h4>
          <p>Structured by area, photographed throughout, written in plain English. Every finding has a severity rating: <em>safety · major · minor · cosmetic · maintenance</em>.</p>
        </div>
        <div class="card card--feature">
          <p class="eyebrow">Visuals</p>
          <h4>Photos throughout</h4>
          <p>Every notable finding has at least one photograph showing what was observed and where on the property.</p>
        </div>
        <div class="card card--feature">
          <p class="eyebrow">Severity ratings</p>
          <h4>Clear, ranked findings</h4>
          <p>Every defect or concern flagged with a severity rating: <em>safety · major · minor · cosmetic · maintenance</em>. So you know what's urgent, what's negotiable, and what's normal wear and tear.</p>
        </div>
      </div>
      <p class="center mt-5"><a href="/sample-report/" class="btn btn--ghost">See a real (redacted) report</a></p>
    </div>
  </section>

  <section>
    <div class="wrap wrap--narrow">
      <div class="section-head center">
        <p class="eyebrow">Pricing</p>
        <h2 class="h-2">One price, no surprises</h2>
      </div>
      <div class="price-tier featured" style="text-align:center;">
        <h3>Pre-purchase building inspection</h3>
        <p class="price">$550 <small>inc. GST</small></p>
        <ul style="text-align:left;">
          <li>Full inspection to AS 4349.1</li>
          <li>40–60 page photo-rich PDF report</li>
          <li>Severity rating on every finding</li>
          <li>Report delivered within 24 hours</li>
        </ul>
        <a href="/book/" class="btn btn--primary btn--full">Book an inspection</a>
      </div>
      <p class="small center mt-4">Combined building + pest inspections launching shortly. <a href="/pricing/">See full pricing &rarr;</a></p>
    </div>
  </section>

  <section class="dark">
    <div class="wrap center">
      <h2 class="h-1">Three minutes to book online.</h2>
      <p class="lede mt-3" style="margin-left:auto;margin-right:auto;">Or ring Acton directly on 0417 875 329.</p>
      <div class="mt-5">
        <a href="/book/" class="btn btn--primary btn--lg">Book an inspection</a>
      </div>
    </div>
  </section>

</BaseLayout>
