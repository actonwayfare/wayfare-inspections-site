---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Pre-purchase building inspections in Mildura';
const description = 'Pre-purchase building inspections in Mildura and surrounds, by a registered builder. Photo-rich written report within 24 hours.';
---
<BaseLayout title={title} description={description}>
  <section class="hero hero--inner">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a><span>·</span>Services</p>
      <h1>One service, done brilliantly.</h1>
      <p class="lede">We focus on pre-purchase building inspections — the inspection a buyer actually needs, written by a registered builder, delivered within 24 hours.</p>
    </div>
  </section>

  <section>
    <div class="wrap wrap--narrow">
      <a href="/services/pre-purchase-building-inspection/" class="card card--feature" style="text-decoration:none;display:block;">
        <p class="eyebrow">Service · Available</p>
        <h3 class="h-3">Pre-purchase building inspection</h3>
        <p>Full structural and aesthetic inspection by a registered builder. Photo-rich written report within 24 hours. $550 inc. GST.</p>
        <p style="color:var(--mallee);margin-top:var(--space-2);font-weight:600;">View service &rarr;</p>
      </a>
    </div>
  </section>
</BaseLayout>
