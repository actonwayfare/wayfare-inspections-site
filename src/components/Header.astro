---
const nav = [
  { href: '/services/', label: 'Services' },
  { href: '/locations/', label: 'Locations' },
  { href: '/about/', label: 'About' },
  { href: '/pricing/', label: 'Pricing' },
  { href: '/faqs/', label: 'FAQs' },
];
const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || (href !== '/' && pathname.startsWith(href));
---
<header class="site-header">
  <div class="wrap header-inner">
    <a href="/" class="brand" aria-label="Wayfare Construction Inspections — home">
      <span class="brand-word">Wayfare</span>
      <span class="brand-sub">Construction Inspections</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {nav.map((item) => (
        <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <a href="tel:+61417875329" class="phone" aria-label="Call 0417 875 329 with questions before booking">
        <span aria-hidden="true">☎</span>
        <span class="phone-number">0417 875 329</span>
      </a>
      <a href="/book/" class="btn btn--primary btn--sm btn-book">Book inspection</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    background: var(--ink);
    color: var(--cream);
    border-bottom: 1px solid var(--ink);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
  }
  .brand {
    text-decoration: none;
    color: var(--cream);
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand-word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 22px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .brand-sub {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-top: 4px;
    opacity: 0.7;
  }
  .site-nav {
    display: none;
    justify-content: center;
    gap: var(--space-4);
  }
  .site-nav a {
    color: var(--cream);
    text-decoration: none;
    font-size: 14px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.85;
    padding: 6px 0;
    border-bottom: 1px solid transparent;
  }
  .site-nav a:hover { opacity: 1; color: var(--sandstone); }
  .site-nav a.active { border-bottom-color: var(--mallee); opacity: 1; }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .header-actions .phone {
    color: var(--cream);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 6px;
    /* Phone digits visible on every screen size — never hide them. */
  }
  .header-actions .phone-number { display: inline; }
  .header-actions .phone:hover { color: var(--sandstone); }

  /* Hide the "Book inspection" button on small screens to save space —
     the sticky bottom bar carries the booking CTA on mobile. */
  .header-actions .btn-book { display: none; }

  @media (max-width: 480px) {
    .brand-sub { display: none; }
    .header-actions .phone { font-size: 12px; }
  }

  @media (min-width: 760px) {
    .site-nav { display: flex; }
    .header-actions .btn-book { display: inline-flex; }
  }
</style>
