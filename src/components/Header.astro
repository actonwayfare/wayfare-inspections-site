---
const nav = [
  { href: '/services/', label: 'Services' },
  { href: '/locations/', label: 'Locations' },
  { href: '/about/', label: 'About' },
  { href: '/pricing/', label: 'Pricing' },
  { href: '/faqs/', label: 'FAQs' },
];
const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || (href !== '/' && pathname.startsWith(href));
---
<header class="site-header">
  <div class="wrap header-inner">
    <a href="/" class="brand" aria-label="Wayfare Construction Inspections — home">
      <span class="brand-mono">
        <img
          src="https://images.squarespace-cdn.com/content/v1/5c6b2a86c2ff61016df57022/1550627261589-5OBKWVCQFA59XFJZPB0T/WAYFARE_1.png?format=500w"
          alt=""
          width="48"
          height="48"
          loading="eager"
        />
      </span>
      <span class="brand-text">
        <img
          class="brand-word"
          src="/images/wayfare-wordmark-white.png"
          alt="WAYFARE"
          width="158"
          height="22"
          loading="eager"
        />
        <span class="brand-sub">Construction Inspections</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {nav.map((item) => (
        <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <a href="tel:+61417875329" class="phone" aria-label="Call 0417 875 329 with questions before booking">
        <svg class="phone-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span class="phone-number">0417 875 329</span>
      </a>
      <a href="/book/" class="btn btn--primary btn--sm btn-book">Book inspection</a>
      <button
        type="button"
        class="nav-toggle"
        id="navToggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobileNav"
      >
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div class="mobile-nav" id="mobileNav" hidden>
    <nav aria-label="Mobile primary">
      <a href="/" class={pathname === '/' ? 'active' : ''}>Home</a>
      {nav.map((item) => (
        <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a>
      ))}
      <a href="/book/" class={isActive('/book/') ? 'active book' : 'book'}>Book inspection →</a>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('navToggle');
    const panel = document.getElementById('mobileNav');
    if (!btn || !panel) return;
    function setOpen (open) {
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      btn.classList.toggle('is-open', open);
      panel.hidden = !open;
      document.body.classList.toggle('nav-open', open);
    }
    btn.addEventListener('click', function () {
      setOpen(panel.hidden);
    });
    // Close when the user taps a link in the panel
    panel.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () { setOpen(false); });
    });
    // Close on Escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !panel.hidden) setOpen(false);
    });
  })();
</script>

<style>
  .site-header {
    background: var(--ink);
    color: var(--cream);
    border-bottom: 1px solid var(--ink);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
  }
  .brand {
    text-decoration: none;
    color: var(--cream);
    display: flex;
    align-items: center;
    gap: 12px;
    line-height: 1;
  }
  .brand-mono {
    flex: none;
    width: 44px;
    height: 44px;
    display: inline-flex;
  }
  .brand-mono img {
    width: 100%;
    height: 100%;
    display: block;
    /* Source PNG is ink-on-transparent; invert + brightness so it reads as cream on dark */
    filter: invert(100%) brightness(0.96) sepia(8%);
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand-word {
    height: 22px;
    width: auto;
    display: block;
  }
  .brand-sub {
    font-family: "Archivo", "Inter", sans-serif;
    font-weight: 500;
    font-size: 9px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    margin-top: 5px;
    opacity: 0.7;
  }
  .site-nav {
    display: none;
    justify-content: center;
    gap: var(--space-4);
  }
  .site-nav a {
    color: var(--cream);
    text-decoration: none;
    font-size: 14px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.85;
    padding: 6px 0;
    border-bottom: 1px solid transparent;
  }
  .site-nav a:hover { opacity: 1; color: var(--sandstone); }
  .site-nav a.active { border-bottom-color: var(--mallee); opacity: 1; }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .header-actions .phone {
    color: var(--cream);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;          /* keep digits on one line, never wrap */
    flex-shrink: 0;
  }
  .header-actions .phone-number { display: inline; white-space: nowrap; }
  .header-actions .phone:hover { color: var(--sandstone); }

  /* Hide "Book inspection" button on small screens — sticky bottom bar carries it on mobile. */
  .header-actions .btn-book { display: none; }

  /* Hamburger — mobile only */
  .nav-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px 8px;
    background: transparent;
    border: 1px solid rgba(245, 239, 227, 0.35);
    border-radius: 6px;
    cursor: pointer;
  }
  .nav-toggle__bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--cream);
    border-radius: 1px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-toggle.is-open .nav-toggle__bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle.is-open .nav-toggle__bar:nth-child(2) { opacity: 0; }
  .nav-toggle.is-open .nav-toggle__bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile drop-down menu panel */
  .mobile-nav {
    background: var(--ink);
    border-top: 1px solid rgba(245, 239, 227, 0.12);
  }
  .mobile-nav nav {
    display: flex;
    flex-direction: column;
    padding: var(--space-2) var(--space-4) var(--space-4);
  }
  .mobile-nav a {
    color: var(--cream);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 500;
    padding: 14px 4px;
    border-bottom: 1px solid rgba(245, 239, 227, 0.08);
  }
  .mobile-nav a:hover { color: var(--sandstone); }
  .mobile-nav a.active { color: var(--sandstone); }
  .mobile-nav a.book {
    margin-top: var(--space-3);
    padding: 16px;
    background: var(--mallee);
    color: var(--cream);
    border: 0;
    border-radius: 6px;
    text-align: center;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .mobile-nav a.book:hover { color: var(--cream); background: #9c3c25; }
  body.nav-open { overflow: hidden; }

  @media (max-width: 480px) {
    /* Keep "Construction Inspections" visible — shrink to fit, tighter letter-spacing. */
    .brand-sub { font-size: 8px; letter-spacing: 0.16em; margin-top: 4px; }
    .brand-mono { width: 36px; height: 36px; }
    .brand-word { height: 16px; }
    .header-actions .phone { font-size: 12px; letter-spacing: 0.04em; }
    .header-actions { gap: var(--space-2); }
    .header-inner { gap: var(--space-2); padding: var(--space-3); }
    .nav-toggle { width: 40px; height: 40px; }
  }
  .phone-icon {
    flex: 0 0 auto;
    opacity: 0.75;
    transition: opacity 0.15s ease;
  }
  .header-actions .phone:hover .phone-icon { opacity: 1; }
  /* Drop the phone icon on narrow phones so the digits don't fight for space. */
  @media (max-width: 420px) {
    .header-actions .phone .phone-icon { display: none; }
    .brand-sub { font-size: 7.5px; letter-spacing: 0.12em; }
  }

  @media (min-width: 760px) {
    .site-nav { display: flex; }
    .header-actions .btn-book { display: inline-flex; }
    .nav-toggle, .mobile-nav { display: none !important; }
  }
</style>
