---
// Mobile-only sticky bottom bar with tap-to-call + book CTAs.
// Hidden on screens >= 760px (the header has the equivalent buttons there).
// Also hidden on the /book/ page itself — redundant once the customer's there.
const pathname = Astro.url.pathname;
const onBookPage = pathname === '/book/' || pathname === '/book';
---
{!onBookPage && (
  <aside class="mobile-sticky" aria-label="Quick actions">
    <a href="tel:+61417875329" class="mobile-sticky__btn mobile-sticky__btn--call" aria-label="Call 0417 875 329 with questions before booking">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      <span>Questions?</span>
    </a>
    <a href="/book/" class="mobile-sticky__btn mobile-sticky__btn--book">
      Book inspection
    </a>
  </aside>
)}

<style>
  .mobile-sticky {
    display: none;
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 60;
    background: var(--ink);
    border-top: 1px solid rgba(245, 239, 227, 0.18);
    box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.18);
    padding: 10px 12px calc(10px + env(safe-area-inset-bottom));
    gap: 8px;
  }
  .mobile-sticky__btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 14px 16px;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    line-height: 1;
    letter-spacing: 0.01em;
    min-height: 48px;
  }
  .mobile-sticky__btn--call {
    background: transparent;
    color: var(--cream);
    border: 1px solid rgba(245, 239, 227, 0.5);
  }
  .mobile-sticky__btn--call:active { background: rgba(245, 239, 227, 0.08); }
  .mobile-sticky__btn--book {
    background: var(--mallee);
    color: var(--cream);
  }
  .mobile-sticky__btn--book:active { background: #9c3c25; }

  @media (max-width: 759px) {
    .mobile-sticky { display: flex; }
    /* Add padding to the page so the sticky bar doesn't hide footer content. */
    body { padding-bottom: calc(72px + env(safe-area-inset-bottom)); }
  }
</style>
